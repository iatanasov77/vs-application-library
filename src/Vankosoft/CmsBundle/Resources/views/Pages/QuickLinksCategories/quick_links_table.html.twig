{# Import Macros #}
{% import "@VSApplication/Macros/alerts.html.twig" as alerts %}
{% import "@VSApplication/Macros/translations.html.twig" as vs_translations %}

<div class="card" id="containerQuickLinks">
    <div class="card-header">
        <div class="float-start" style="height:30px; padding-top:10px;">{{ 'vs_cms.template.quick_links' | trans( {},'VSCmsBundle' ) }}</div>
        <div class="btn-group float-end">
            <a class="btn btn-primary btnQuickLink" id="btnQuickLink" 
                title="{{ 'vs_cms.template.button_banner_create' | trans( {},'VSCmsBundle' ) }}" 
                href="javascript:void(0);"
                data-placeId="{{ item.id }}"
                data-itemId="0"
            >
                {{ 'vs_cms.template.button_banner_create' | trans( {},'VSCmsBundle' ) }}
            </a>&nbsp;
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        {% if item.quickLinks | length > 0 %}
            <table class="table table-striped table-advance table-hover" id="tblQuickLinks">
                <tbody id="quickLinksTableBody">
                    {% for quickLink in item.quickLinks %}
                        <tr data-node-id="{{ quickLink.id }}"
                            data-position="{{ quickLink.priority }}"
                            id="quickLink-{{ quickLink.id }}"
                        >
                            <td>
                                <i class="fas fa-arrows-alt"
                                    title="{{ 'vs_application.form.drag_and_drop_title' | trans( {},'VSApplicationBundle' ) }}"
                                    style="cursor: pointer;"
                                ></i>
                            </td>
                            
                            <td>{{ quickLink.title }}</td>
                            <td>
                                {% if quickLink.public %}
                                    <i class="fas fa-check" style="color: #82c91e;">
                                {% else %}
                                    <i class="fas fa-times" style="color: #ff1e1e;"></i>
                                {% endif %}
                            </td>
                            
                            {# <td>{{ vs_translations.flags( bannersTranslations[banner.id] ) }}</td> #}
                            
                            <td>
                                <a href="javascript:void(0);"
                                   class="btn btn-primary btnQuickLink"
                                   data-placeId="{{ item.id }}"
                                   data-itemId="{{ quickLink.id }}"
                                   title="{{ 'vs_application.template.items_index_row_action_edit' | trans( {},'VSApplicationBundle' ) }}"
                                >
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a class="btn btn-danger btnQuickLinkDelete btnDeleteResource"
                                    href="{{ path('vs_cms_quick_link_delete', {'id': quickLink.id}) }}"
                                    data-csrfToken="{{ csrf_token( quickLink.id ) }}" 
                                    data-redirectUrl="{{ path( 'vs_cms_quick_link_category_update', {'id': item.id} ) }}"
                                    title="{{ 'vs_application.template.items_index_row_action_delete' | trans( {},'VSApplicationBundle' ) }}"
                                >
                                    <i class="icon_close_alt2"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            {{ alerts.info( 'vs_application.template.there_are_no_items_to_display' | trans( {},'VSApplicationBundle' ) ) }}
        {% endif %}
    </div>
</div>